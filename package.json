{
  "name": "tg-cf-ai-bot",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler pages dev public --compatibility-date=2026-07-14 --compatibility-flag=nodejs_compat",
    "deploy": "wrangler pages deploy public --project-name=tg-cf-ai-bot",
    "cf-typegen": "wrangler types",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "grammy": "^1.38.3",
    "hono": "^4.9.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260708.1",
    "typescript": "^5.8.3",
    "wrangler": "^4.100.0",
    "@types/node": "^24.0.0"
  },
  "cloudflare": {
    "bindings": {
      "BOT_TOKEN": {
        "description": "在 Telegram 找 @BotFather 发送 /newbot 创建机器人后拿到的 Token，格式类似 123456789:AAExxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
      },
      "TELEGRAM_WEBHOOK_SECRET": {
        "description": "随便填一段随机字符串（建议 20 位以上），部署完成后需要用这段字符串注册 Telegram Webhook，作用是防止别人伪造请求"
      }
    }
  }
}
